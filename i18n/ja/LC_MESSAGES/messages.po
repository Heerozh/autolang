#: src/autolang/cli.py:22
msgid "CLI utilities for gettext/Babel/OpenAI-compatible translation flows."
msgstr "gettext/Babel/OpenAI互換の翻訳フロー用のCLIユーティリティ。"

#: src/autolang/cli.py:30
msgid "Initialize project configuration and translation assets."
msgstr "プロジェクト設定と翻訳アセットを初期化します。"

#: src/autolang/cli.py:36
msgid "Sync gettext/Babel catalog files."
msgstr "gettext/Babelカタログファイルを同期します。"

#: src/autolang/cli.py:42
msgid "Translate pending catalog entries through a compatible API."
msgstr "互換性のあるAPIを通じて保留中のカタログエントリを翻訳します。"

#: src/autolang/cli.py:71 src/autolang/cli.py:97 src/autolang/cli.py:115
msgid "Directory used to store POT and PO files."
msgstr "POTおよびPOファイルを保存するディレクトリ。"

#: src/autolang/cli.py:79
msgid "Target locale to initialize. Repeat for multiple locales."
msgstr "初期化するターゲットロケール。複数のロケールには繰り返し指定します。"

#: src/autolang/cli.py:87 src/autolang/cli.py:105
msgid "Source path to scan for gettext messages. Repeat for multiple paths."
msgstr "gettextメッセージをスキャンするソースパス。複数のパスには繰り返し指定します。"

#: src/autolang/cli.py:123
msgid "Source path hint used to scope translation batches by file."
msgstr "ファイルごとに翻訳バッチをスコープするためのソースパスヒント。"

#: src/autolang/cli.py:129
msgid "Model name. Defaults to AUTOLANG_MODEL or OPENAI_MODEL."
msgstr "モデル名。デフォルトはAUTOLANG_MODELまたはOPENAI_MODELです。"

#: src/autolang/cli.py:139
msgid ""
"OpenAI-compatible API base URL. Defaults to AUTOLANG_BASE_URL or "
"OPENAI_BASE_URL."
msgstr "OpenAI互換APIベースURL。デフォルトはAUTOLANG_BASE_URLまたはOPENAI_BASE_URLです。"

#: src/autolang/cli.py:147
msgid "API key. Defaults to AUTOLANG_API_KEY or OPENAI_API_KEY."
msgstr "APIキー。デフォルトはAUTOLANG_API_KEYまたはOPENAI_API_KEYです。"

#: src/autolang/cli.py:153
msgid "Maximum untranslated entries to send in one model request."
msgstr "1回のモデルリクエストで送信する未翻訳エントリの最大数。"

#: src/autolang/translator.py:207
#, python-brace-format
msgid "Translation request failed with HTTP {code}: {details}"
msgstr "翻訳リクエストがHTTP {code}で失敗しました: {details}"

#: src/autolang/translator.py:213
#, python-brace-format
msgid "Translation request failed: {reason}"
msgstr "翻訳リクエストが失敗しました: {reason}"

#: src/autolang/translator.py:219
msgid "Translation API returned invalid JSON."
msgstr "翻訳APIが無効なJSONを返しました。"

#: src/autolang/translator.py:222
msgid "Translation API response must be a JSON object."
msgstr "翻訳APIのレスポンスはJSONオブジェクトである必要があります。"

#: src/autolang/translator.py:236
msgid "Model response must contain a translations list."
msgstr "モデルのレスポンスには翻訳リストが含まれている必要があります。"

#: src/autolang/translator.py:239
msgid "Model response count does not match the number of requested entries."
msgstr "モデルのレスポンス数がリクエストされたエントリ数と一致しません。"

#: src/autolang/translator.py:245
msgid "Each translation item must be an object."
msgstr "各翻訳アイテムはオブジェクトである必要があります。"

#: src/autolang/translator.py:248
msgid "Model response indexes must match the original request order."
msgstr "モデルのレスポンスインデックスは元のリクエスト順序と一致する必要があります。"

#: src/autolang/translator.py:255
msgid "Singular translation items must contain text."
msgstr "単数形の翻訳アイテムにはtextが含まれている必要があります。"

#: src/autolang/translator.py:263
msgid "Plural translation items must contain plural_texts."
msgstr "複数形の翻訳アイテムにはplural_textsが含まれている必要があります。"

#: src/autolang/translator.py:268
msgid "Plural translation inputs must define expected_plural_forms."
msgstr "複数形の翻訳入力にはexpected_plural_formsを定義する必要があります。"

#: src/autolang/translator.py:272
msgid ""
"Plural translation count does not match the target locale plural forms."
msgstr "複数形の翻訳数がターゲットロケールの複数形フォームと一致しません。"

#: src/autolang/translator.py:276
msgid "Plural translation items must contain only string forms."
msgstr "複数形の翻訳アイテムには文字列フォームのみが含まれている必要があります。"

#: src/autolang/translator.py:284
msgid "Translation API response is missing choices."
msgstr "翻訳APIのレスポンスにchoicesがありません。"

#: src/autolang/translator.py:288
msgid "Translation API response choice is invalid."
msgstr "翻訳APIのレスポンスchoiceが無効です。"

#: src/autolang/translator.py:292
msgid "Translation API response is missing a message."
msgstr "翻訳APIのレスポンスにmessageがありません。"

#: src/autolang/translator.py:308
msgid "Translation API message content is missing text."
msgstr "翻訳APIのmessage contentにtextがありません。"

#: src/autolang/translator.py:317
msgid "Model response did not contain JSON."
msgstr "モデルのレスポンスにJSONが含まれていませんでした。"

#: src/autolang/translator.py:321
msgid "Model response did not contain valid JSON."
msgstr "モデルのレスポンスに有効なJSONが含まれていませんでした。"

#: src/autolang/translator.py:324
msgid "Model response JSON must be an object."
msgstr "モデルのレスポンスJSONはオブジェクトである必要があります。"

#: src/autolang/commands/translate.py:23
msgid ""
"Missing model configuration. Set --model or AUTOLANG_MODEL/OPENAI_MODEL."
msgstr "モデル設定がありません。--model または AUTOLANG_MODEL/OPENAI_MODEL を設定してください。"

#: src/autolang/commands/translate.py:27
msgid ""
"Missing base URL configuration. Set --base-url or "
"AUTOLANG_BASE_URL/OPENAI_BASE_URL."
msgstr ""
"ベースURL設定がありません。--base-url または AUTOLANG_BASE_URL/OPENAI_BASE_URL を設定してください。"

#: src/autolang/commands/translate.py:30
msgid "--batch-size must be greater than 0."
msgstr "--batch-size は0より大きい値である必要があります。"

#: src/autolang/commands/translate.py:100
msgid "Singular translation response is missing text."
msgstr "単数形の翻訳応答にテキストが含まれていません。"

#: src/autolang/commands/translate.py:105
msgid "Plural translation response is missing plural_texts."
msgstr "複数形の翻訳応答に plural_texts が含まれていません。"

#: src/autolang/commands/translate.py:278
msgid "Plural translation count does not match target plural slots."
msgstr "複数形の翻訳カウントがターゲットの複数形スロットと一致しません。"
